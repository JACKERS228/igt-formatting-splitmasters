    <paragraphs>
      <paragraph guid="c79c4b80-79f2-4667-90fa-d59c93f24cdf">
        <phrases>
          <phrase guid="db76055e-645a-4308-9c8d-9f6bec3f5eb7">
            <item type="txt" lang="sjo-x-manchu">ᡝᠷᡝ ᠣᠴᡞ ᠠᠪᡣᠠᡞ ᠸᡝᡥᡞᠶᡝᡥᡝ ᡝᡪᡝᠨ ᡞ ᡥᡝᠰᡝ ᠪᡝ ᠠᠯᡞᡫᡞ , ᠮᡠᡣᡩᡝᠨ ᡞ ᡥᠠᠷᠠᡢᡤᠠ ᠪᠠ ᡩᡝᠷᡞ ᡨᠣᠮᡞᠯᠠᡫᡞ , ᡞᠯᡞ ᠪᠠ ᡩᡝ ᡨᡝᠪᡠᠨᡝᠮᡝ , ᡤᡠᠷᡠᠨ ᡞ ᡪᡝᠴᡝᠨ ᠪᡝ ᠰᡝᠷᡝᠮᡧᡝᠮᡝ ᡨᡠᠸᠠᡣᡞᠶᠠᠷᠠ ᡝᠮᡠ ᠮᡞᡢᡤᠠᠨ ᠰᡞᠪᡝ  ᡞ ᡥᠠᡫᠠᠨ ᠴᠣᡠᡥᠠ ᡞ ᡪᠠᡞ ᠮᡝᠶᡝᠨ ᡞᠨᡠ 。</item>
            <item type="segnum" lang="en">1</item>
