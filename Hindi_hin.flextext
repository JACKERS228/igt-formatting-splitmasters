    <paragraphs>
      <paragraph guid="2b39bf21-34f8-498c-af13-7f6840a9b435">
        <phrases>
          <phrase guid="db5e40f7-24d8-466a-8d87-2e4f8400a617">
            <item type="txt" lang="hi">इंदौर में जिस प्रकार से शेरोंवाली माँ की पूजा आस्था तथा विश्वास के साथ की जाती है उसी विश्वास के साथ कोलकाता में काली माँ की पूजा की जाती है ।</item>
