          <t>Nday</t>
        </w>
      </s>
    </p>
    <p xml:id="_UTOLAF09Aug12.text.1.p.48">
      <s xml:id="_UTOLAF09Aug12.text.1.p.48.s.1">
        <t>"Ndee nushyign', tamaagn nts'ą̈' nushyign' tu tth'itu' nts'ą̈' tah shoh eedah."</t>
        <segnum>48</segnum>
        <w xml:id="_UTOLAF09Aug12.text.1.p.48.s.1.w.1">
          <t>Ndee</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.48.s.1.w.2">
          <t>nushyign'</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.48.s.1.w.3">
          <t>tamaagn</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.48.s.1.w.4">
          <t>nts'ą̈'</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.48.s.1.w.5">
          <t>nushyign'</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.48.s.1.w.6">
          <t>tu</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.48.s.1.w.7">
          <t>tth'itu'</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.48.s.1.w.8">
          <t>nts'ą̈'</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.48.s.1.w.9">
          <t>tah</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.48.s.1.w.10">
          <t>shoh</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.48.s.1.w.11">
          <t>eedah</t>
        </w>
      </s>
    </p>
    <p xml:id="_UTOLAF09Aug12.text.1.p.49">
      <s xml:id="_UTOLAF09Aug12.text.1.p.49.s.1">
        <t>"Maa ni'uhshya' nts'ą̈' nok-'įį!" </t>
        <segnum>49.1</segnum>
        <w xml:id="_UTOLAF09Aug12.text.1.p.49.s.1.w.1">
          <t>Maa</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.49.s.1.w.2">
          <t>ni'uhshya'</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.49.s.1.w.3">
          <t>nts'ą̈'</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.49.s.1.w.4">
          <t>nok</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.49.s.1.w.5">
          <t>'įį</t>
        </w>
      </s>
      <s xml:id="_UTOLAF09Aug12.text.1.p.49.s.2">
        <t>nih.</t>
        <segnum>49.2</segnum>
        <w xml:id="_UTOLAF09Aug12.text.1.p.49.s.2.w.1">
          <t>nih</t>
        </w>
      </s>
    </p>
    <p xml:id="_UTOLAF09Aug12.text.1.p.50">
      <s xml:id="_UTOLAF09Aug12.text.1.p.50.s.1">
        <t>"Ayt'oo, ayt'oo," udihnih.</t>
        <segnum>50</segnum>
        <w xml:id="_UTOLAF09Aug12.text.1.p.50.s.1.w.1">
          <t>Ayt'oo</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.50.s.1.w.2">
          <t>ayt'oo</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.50.s.1.w.3">
          <t>udihnih</t>
        </w>
      </s>
    </p>
    <p xml:id="_UTOLAF09Aug12.text.1.p.51">
      <s xml:id="_UTOLAF09Aug12.text.1.p.51.s.1">
        <t>Nushyign' tah ts'aahaal.</t>
        <segnum>51</segnum>
        <w xml:id="_UTOLAF09Aug12.text.1.p.51.s.1.w.1">
          <t>Nushyign'</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.51.s.1.w.2">
          <t>tah</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.51.s.1.w.3">
          <t>ts'aahaal</t>
        </w>
      </s>
    </p>
    <p xml:id="_UTOLAF09Aug12.text.1.p.52">
      <s xml:id="_UTOLAF09Aug12.text.1.p.52.s.1">
        <t>Howard iin du' nushyign' tah hiik'anehta'.</t>
        <segnum>52</segnum>
        <w xml:id="_UTOLAF09Aug12.text.1.p.52.s.1.w.1">
          <t>Howard</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.52.s.1.w.2">
          <t>iin</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.52.s.1.w.3">
          <t>du'</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.52.s.1.w.4">
          <t>nushyign'</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.52.s.1.w.5">
          <t>tah</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.52.s.1.w.6">
          <t>hiik'anehta'</t>
        </w>
      </s>
    </p>
    <p xml:id="_UTOLAF09Aug12.text.1.p.53">
      <s xml:id="_UTOLAF09Aug12.text.1.p.53.s.1">
        <t>&lt;Ay&gt; ch'itay eh huxah ninįįshyah tl'aan nduugn nts'ą' natetshyah le' ishyiit nts'ą', k'at'eey udakkadn.</t>
