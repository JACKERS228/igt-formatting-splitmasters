        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.53.s.1.w.11">
          <t>ishyiit</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.53.s.1.w.12">
          <t>nts'ą'</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.53.s.1.w.13">
