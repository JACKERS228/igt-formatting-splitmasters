                <item type="txt" lang="tau">nats'elmoo</item>
              </word>
              <word>
                <item type="punct" lang="tau">.</item>
              </word>
            </words>
            <item type="gls" lang="en">Truck</item>
          </phrase>
        </phrases>
      </paragraph>
      <paragraph guid="a9980478-d07b-487e-a25c-4d6782fd82dd" />
      <paragraph guid="4c04aa3b-c5b0-4234-8a20-a6feb298b52a">
        <phrases>
          <phrase guid="3d169702-53d4-4a85-93c2-41cfa841e2e6">
            <item type="txt" lang="tau">Tąy hǫǫteeł niign nats'elsüü eh.</item>
            <item type="segnum" lang="en">6</item>
