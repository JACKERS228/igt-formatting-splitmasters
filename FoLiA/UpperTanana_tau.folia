    </p>
    <p xml:id="_UTOLAF09Aug12.text.1.p.43">
      <s xml:id="_UTOLAF09Aug12.text.1.p.43.s.1">
        <t>"Ąą, shiy ch'ale agndeel," udihnih.</t>
        <segnum>43</segnum>
        <w xml:id="_UTOLAF09Aug12.text.1.p.43.s.1.w.1">
          <t>Ąą</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.43.s.1.w.2">
          <t>shiy</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.43.s.1.w.3">
          <t>ch'ale</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.43.s.1.w.4">
          <t>agndeel</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.43.s.1.w.5">
          <t>udihnih</t>
        </w>
      </s>
    </p>
    <p xml:id="_UTOLAF09Aug12.text.1.p.44">
      <s xml:id="_UTOLAF09Aug12.text.1.p.44.s.1">
        <t>K'at'eey minaniich'akthädn eh ay du' agnthäł nts'ą̈' t'eey uu'akdiih ch'ale.</t>
        <segnum>44</segnum>
        <w xml:id="_UTOLAF09Aug12.text.1.p.44.s.1.w.1">
          <t>K'at'eey</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.44.s.1.w.2">
          <t>minaniich'akthädn</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.44.s.1.w.3">
          <t>eh</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.44.s.1.w.4">
          <t>ay</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.44.s.1.w.5">
          <t>du'</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.44.s.1.w.6">
          <t>agnthäł</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.44.s.1.w.7">
          <t>nts'ą̈'</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.44.s.1.w.8">
          <t>t'eey</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.44.s.1.w.9">
          <t>uu'akdiih</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.44.s.1.w.10">
          <t>ch'ale</t>
        </w>
      </s>
    </p>
    <p xml:id="_UTOLAF09Aug12.text.1.p.45">
      <s xml:id="_UTOLAF09Aug12.text.1.p.45.s.1">
        <t>Ch'itay du' k'at'eey minaniich'akthädn.</t>
        <segnum>45</segnum>
        <w xml:id="_UTOLAF09Aug12.text.1.p.45.s.1.w.1">
          <t>Ch'itay</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.45.s.1.w.2">
          <t>du'</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.45.s.1.w.3">
          <t>k'at'eey</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.45.s.1.w.4">
          <t>minaniich'akthädn</t>
        </w>
      </s>
    </p>
    <p xml:id="_UTOLAF09Aug12.text.1.p.46">
      <s xml:id="_UTOLAF09Aug12.text.1.p.46.s.1">
        <t>Shuudehka:::t.</t>
        <segnum>46</segnum>
        <w xml:id="_UTOLAF09Aug12.text.1.p.46.s.1.w.1">
          <t>Shuudehka</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.46.s.1.w.2">
          <t>t</t>
