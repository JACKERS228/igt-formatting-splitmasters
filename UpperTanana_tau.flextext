              </word>
              <word>
                <item type="punct" lang="tau">.</item>
              </word>
            </words>
            <item type="gls" lang="en">We hunt at the roadside.</item>
          </phrase>
        </phrases>
      </paragraph>
      <paragraph guid="544e3f2c-a7a3-4489-88b4-c9188c566251">
        <phrases>
          <phrase guid="20db2cae-4222-42e9-bc05-c4e6998959a6">
