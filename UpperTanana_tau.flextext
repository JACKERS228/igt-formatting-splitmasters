                <item type="txt" lang="tau">niign</item>
              </word>
              <word guid="587196dd-f323-46ad-be28-2f0737514876">
                <item type="txt" lang="tau">nats'elsüü</item>
              </word>
              <word guid="c9b84ef9-2e6f-4655-b1e3-36d63121e151">
                <item type="txt" lang="tau">eh</item>
              </word>
              <word>
                <item type="punct" lang="tau">.</item>
              </word>
            </words>
            <item type="gls" lang="en">We hunt at the side of the highway.</item>
          </phrase>
        </phrases>
      </paragraph>
      <paragraph guid="64fe4daf-e803-4f72-b9f7-e0dfdd92ab2c">
        <phrases>
          <phrase guid="d7387dd3-3955-4f00-80f4-ab12cd76c355">
            <item type="txt" lang="tau">Taylor Highway hǫǫsi'.</item>
            <item type="segnum" lang="en">7</item>
            <words>
              <word guid="8fa529c9-608f-4f09-ab6f-87519b9b7471">
                <item type="txt" lang="tau">Taylor</item>
              </word>
              <word guid="1efc397f-51c2-4153-ab69-815f34842fe4">
                <item type="txt" lang="tau">Highway</item>
              </word>
              <word guid="b36d053a-9ab8-4d18-a80d-09066a72e493">
                <item type="txt" lang="tau">hǫǫsi'</item>
              </word>
              <word>
                <item type="punct" lang="tau">.</item>
              </word>
            </words>
            <item type="gls" lang="en">They call it Taylor Highway.</item>
          </phrase>
        </phrases>
      </paragraph>
      <paragraph guid="a6773b96-98d2-41f1-b464-432ca96a096d">
        <phrases>
          <phrase guid="ff6382d0-355e-4f1f-8f5a-6b4a406607bc">
            <item type="txt" lang="tau">Jah t'eey tąy teeł Taylor Highway mǫǫsi'.</item>
            <item type="segnum" lang="en">8</item>
            <words>
              <word guid="da74c781-10b8-4b69-874b-5369acdf229c">
                <item type="txt" lang="tau">Jah</item>
              </word>
              <word guid="edbd6f02-700d-430c-9c6b-d9f24b83f3c4">
                <item type="txt" lang="tau">t'eey</item>
              </word>
              <word guid="70a9b611-6c1b-45fe-ab02-6bf8d2a44857">
                <item type="txt" lang="tau">tąy</item>
              </word>
              <word guid="038c7c8b-966c-489f-91b8-5fae4c546bb3">
                <item type="txt" lang="tau">teeł</item>
              </word>
              <word guid="8fa529c9-608f-4f09-ab6f-87519b9b7471">
                <item type="txt" lang="tau">Taylor</item>
              </word>
              <word guid="1efc397f-51c2-4153-ab69-815f34842fe4">
                <item type="txt" lang="tau">Highway</item>
              </word>
              <word guid="becd564a-89f5-4664-8b9d-c04d13b938e9">
                <item type="txt" lang="tau">mǫǫsi'</item>
              </word>
              <word>
                <item type="punct" lang="tau">.</item>
              </word>
            </words>
            <item type="gls" lang="en">Here on the road that is called Taylor Highway.</item>
          </phrase>
        </phrases>
      </paragraph>
      <paragraph guid="94441da1-e4e7-41d1-bf0f-816a850ab3e4">
        <phrases>
          <phrase guid="a1d352f8-58e6-4d71-9545-ec3e738201f0">
            <item type="txt" lang="tau">Ay ishyiit nts'änh noo nats'atdäl eh.</item>
            <item type="segnum" lang="en">9</item>
            <words>
              <word guid="9b953d27-8615-43cd-9018-c98779428446">
                <item type="txt" lang="tau">Ay</item>
              </word>
              <word guid="fc667181-e5de-434a-8129-d36dc82fb31d">
                <item type="txt" lang="tau">ishyiit</item>
              </word>
              <word guid="4462a0f4-8261-4b12-b448-423bf766ccf1">
                <item type="txt" lang="tau">nts'änh</item>
              </word>
              <word guid="095d36f1-f02b-4466-a7cb-cac3cfe34e0e">
                <item type="txt" lang="tau">noo</item>
              </word>
              <word guid="f3e19132-3e58-40ca-bea0-c6f3f73982d8">
                <item type="txt" lang="tau">nats'atdäl</item>
              </word>
              <word guid="c9b84ef9-2e6f-4655-b1e3-36d63121e151">
                <item type="txt" lang="tau">eh</item>
              </word>
              <word>
                <item type="punct" lang="tau">.</item>
              </word>
            </words>
            <item type="gls" lang="en">And from there we were going back.</item>
          </phrase>
        </phrases>
      </paragraph>
      <paragraph guid="40ccb794-589b-41d8-9eed-5f42c953acf1">
        <phrases>
          <phrase guid="d516439d-903f-4a6b-8234-c18bd6b8efe5">
            <item type="txt" lang="tau">T'axoh neeshyah Naambia Niign' hu'ąą dą' nts'ą̈' nats'atdäl eh.</item>
            <item type="segnum" lang="en">10</item>
            <words>
              <word guid="251cf171-edd2-41f9-b5a0-7d06c122c47b">
                <item type="txt" lang="tau">T'axoh</item>
              </word>
              <word guid="27620858-4b30-45c7-a6e1-eb63ddaa0e63">
                <item type="txt" lang="tau">neeshyah</item>
              </word>
              <word guid="ee0784e2-84f7-4425-a809-86e0ffaa23a2">
                <item type="txt" lang="tau">Naambia</item>
              </word>
              <word guid="5c35ee18-beb0-4dc4-93fb-fdb3ed1f8d7c">
                <item type="txt" lang="tau">Niign'</item>
              </word>
              <word guid="c7908972-6f74-438c-b2ec-18404b00f005">
                <item type="txt" lang="tau">hu'ąą</item>
              </word>
              <word guid="c155e131-9b11-4bf8-affc-c2d28c3b712e">
                <item type="txt" lang="tau">dą'</item>
              </word>
              <word guid="8f4292e9-703a-4dbe-8d5b-73a277d7534c">
                <item type="txt" lang="tau">nts'ą̈'</item>
              </word>
              <word guid="f3e19132-3e58-40ca-bea0-c6f3f73982d8">
                <item type="txt" lang="tau">nats'atdäl</item>
              </word>
              <word guid="c9b84ef9-2e6f-4655-b1e3-36d63121e151">
                <item type="txt" lang="tau">eh</item>
              </word>
              <word>
                <item type="punct" lang="tau">.</item>
              </word>
            </words>
            <item type="gls" lang="en">Finally we were going back to our house in Northway.</item>
          </phrase>
        </phrases>
      </paragraph>
      <paragraph guid="f925e94c-575e-49db-872e-f49bb98d04ec">
        <phrases>
          <phrase guid="7eb55b7b-a1ee-48c8-b3fb-bdd74db313c9">
            <item type="txt" lang="tau">Dahdǫǫ shoh dat-sąy kah hach'edagn'įį'.</item>
            <item type="segnum" lang="en">11</item>
            <words>
              <word guid="51d3d69b-cadf-4f84-8e18-a60760fd1481">
                <item type="txt" lang="tau">Dahdǫǫ</item>
              </word>
              <word guid="79a1157b-6a4d-4e96-9a58-ea3b1dcb3982">
                <item type="txt" lang="tau">shoh</item>
              </word>
              <word guid="3f6a9c07-7d09-4572-8e5c-ada2bb95ce16">
                <item type="txt" lang="tau">dat</item>
              </word>
              <word>
                <item type="punct" lang="tau">-</item>
              </word>
              <word guid="24cb07b9-788d-4c7f-83a2-e09b09200ecd">
                <item type="txt" lang="tau">sąy</item>
              </word>
              <word guid="7c3e7300-d3dd-4d01-9098-a4b30bc57435">
                <item type="txt" lang="tau">kah</item>
              </word>
              <word guid="31361a40-c0b7-4192-be12-657b9fcb78ae">
                <item type="txt" lang="tau">hach'edagn'įį'</item>
              </word>
              <word>
                <item type="punct" lang="tau">.</item>
              </word>
            </words>
            <item type="gls" lang="en">From uphill I was looking around for black bears.</item>
          </phrase>
        </phrases>
      </paragraph>
      <paragraph guid="d1e6f6f6-78cf-4592-99d5-cfa123f9195f">
        <phrases>
          <phrase guid="07dc0b46-8ee7-4992-862b-9e96967f82b8">
            <item type="txt" lang="tau">Ay chih ts'eldeeł.</item>
            <item type="segnum" lang="en">12</item>
            <words>
              <word guid="9b953d27-8615-43cd-9018-c98779428446">
                <item type="txt" lang="tau">Ay</item>
              </word>
              <word guid="3568ecba-7440-45ca-919f-278ca5fa9484">
                <item type="txt" lang="tau">chih</item>
              </word>
              <word guid="e0395abd-dd0a-4bf1-b6b1-7c09945a9772">
                <item type="txt" lang="tau">ts'eldeeł</item>
              </word>
              <word>
                <item type="punct" lang="tau">.</item>
              </word>
            </words>
            <item type="gls" lang="en">And also we eat them.</item>
          </phrase>
        </phrases>
      </paragraph>
      <paragraph guid="3c8b029e-9dec-49c6-bc4c-5d938160d8be">
        <phrases>
          <phrase guid="fa114b62-075a-48d3-a2cc-2ee6821123f9">
            <item type="txt" lang="tau">Noołuut tah elk'ah, ushyi' nsǫǫ!</item>
            <item type="segnum" lang="en">13</item>
            <words>
              <word guid="3626792c-2c48-4790-92d8-8cd74a39d908">
                <item type="txt" lang="tau">Noołuut</item>
              </word>
              <word guid="ec98ad2e-f253-41b6-9c3f-6feb734e751f">
                <item type="txt" lang="tau">tah</item>
              </word>
              <word guid="2431e85e-0f76-48c0-9b9a-7c6a513ce570">
                <item type="txt" lang="tau">elk'ah</item>
              </word>
              <word>
                <item type="punct" lang="tau">,</item>
              </word>
              <word guid="2956b0ae-06b7-4153-b0e2-2888a34a6555">
                <item type="txt" lang="tau">ushyi'</item>
              </word>
              <word guid="a10f2113-874e-4304-8f61-d0daf614698e">
                <item type="txt" lang="tau">nsǫǫ</item>
              </word>
              <word>
                <item type="punct" lang="tau">!</item>
              </word>
            </words>
            <item type="gls" lang="en">In the fall they are fat, their meat is good!</item>
          </phrase>
        </phrases>
      </paragraph>
      <paragraph guid="2a52a183-3e89-4425-b156-4052b47d8306">
        <phrases>
          <phrase guid="5d985875-9deb-4481-a4cc-a44859459535">
            <item type="txt" lang="tau">Ay tl'aan dǫǫ nats'atdäl eh.</item>
            <item type="segnum" lang="en">14</item>
            <words>
              <word guid="9b953d27-8615-43cd-9018-c98779428446">
                <item type="txt" lang="tau">Ay</item>
              </word>
              <word guid="3a8d4e9e-438f-4142-906f-78a1fca23b60">
                <item type="txt" lang="tau">tl'aan</item>
              </word>
              <word guid="59b986da-31c6-4f6a-b430-226c209b8a01">
                <item type="txt" lang="tau">dǫǫ</item>
              </word>
              <word guid="f3e19132-3e58-40ca-bea0-c6f3f73982d8">
                <item type="txt" lang="tau">nats'atdäl</item>
              </word>
              <word guid="c9b84ef9-2e6f-4655-b1e3-36d63121e151">
                <item type="txt" lang="tau">eh</item>
              </word>
              <word>
                <item type="punct" lang="tau">.</item>
              </word>
            </words>
            <item type="gls" lang="en">And then from way up there we were going back. </item>
          </phrase>
        </phrases>
      </paragraph>
      <paragraph guid="83277825-1655-40f2-b453-c42684473799">
        <phrases>
          <phrase guid="f80060c6-b3ee-4918-bf0b-2c3971a29d73">
            <item type="txt" lang="tau">Jah tąy k'üü noodlee iin nah'ogn tourist huhinay iin hushyah choh heetąą nts'ą̈'.</item>
            <item type="segnum" lang="en">15</item>
            <words>
              <word guid="da74c781-10b8-4b69-874b-5369acdf229c">
                <item type="txt" lang="tau">Jah</item>
              </word>
              <word guid="70a9b611-6c1b-45fe-ab02-6bf8d2a44857">
                <item type="txt" lang="tau">tąy</item>
              </word>
              <word guid="a7de60fd-7e4d-4b82-b72f-00875a58258a">
                <item type="txt" lang="tau">k'üü</item>
              </word>
              <word guid="9f438a05-a089-40dd-9114-8aa3a84eb4e2">
                <item type="txt" lang="tau">noodlee</item>
              </word>
              <word guid="31b9e81b-c963-4beb-8852-420905a52a8a">
                <item type="txt" lang="tau">iin</item>
              </word>
              <word guid="10f29adc-7b96-4640-a641-235f653b6548">
                <item type="txt" lang="tau">nah'ogn</item>
              </word>
              <word guid="2aec8138-ffee-42e2-ba35-503b2efbda75">
                <item type="txt" lang="tau">tourist</item>
              </word>
              <word guid="9c885790-7456-4393-b429-7ae4d7c59007">
                <item type="txt" lang="tau">huhinay</item>
              </word>
              <word guid="31b9e81b-c963-4beb-8852-420905a52a8a">
                <item type="txt" lang="tau">iin</item>
              </word>
              <word guid="abaed24c-ba84-447e-9eb0-cb16685a160e">
                <item type="txt" lang="tau">hushyah</item>
              </word>
              <word guid="073134ae-c4ef-449b-b8a1-a416ad66f317">
                <item type="txt" lang="tau">choh</item>
              </word>
              <word guid="49e199a5-5867-465f-9524-8d64613dd2d7">
                <item type="txt" lang="tau">heetąą</item>
              </word>
              <word guid="8f4292e9-703a-4dbe-8d5b-73a277d7534c">
                <item type="txt" lang="tau">nts'ą̈'</item>
              </word>
              <word>
                <item type="punct" lang="tau">.</item>
              </word>
            </words>
            <item type="gls" lang="en">Here, next to the road, white people, the ones they call tourists, had parked their big camper.</item>
          </phrase>
        </phrases>
      </paragraph>
      <paragraph guid="936e5f35-a9d1-4e3c-91d2-a8998d13eef5">
        <phrases>
          <phrase guid="195fa566-e78a-41c3-a210-314e8f7aa314">
            <item type="txt" lang="tau">Ch'itay &lt;du'&gt;, ch'ikąy' u'aat eh ishyiit nahideeh nts'ą̈' /picture/ shoh dat-sąy eh ehtsayh.</item>
            <item type="segnum" lang="en">16</item>
            <words>
              <word guid="3e2cdf88-1c10-482d-8fee-f4324f393a9c">
                <item type="txt" lang="tau">Ch'itay</item>
              </word>
              <word>
                <item type="punct" lang="tau">&lt;</item>
              </word>
              <word guid="8f8da878-6648-4c0d-b61b-8a1db78a468b">
                <item type="txt" lang="tau">du'</item>
              </word>
              <word>
                <item type="punct" lang="tau">&gt;,</item>
              </word>
              <word guid="916ca74a-8189-49a3-b702-a5e930bec1ab">
                <item type="txt" lang="tau">ch'ikąy'</item>
              </word>
              <word guid="c87838ff-b560-4218-b4a4-9c2795ec3879">
                <item type="txt" lang="tau">u'aat</item>
              </word>
              <word guid="c9b84ef9-2e6f-4655-b1e3-36d63121e151">
                <item type="txt" lang="tau">eh</item>
              </word>
              <word guid="fc667181-e5de-434a-8129-d36dc82fb31d">
                <item type="txt" lang="tau">ishyiit</item>
              </word>
              <word guid="e66eb6a9-1c4e-4bea-99bb-dc99951861b8">
                <item type="txt" lang="tau">nahideeh</item>
              </word>
              <word guid="8f4292e9-703a-4dbe-8d5b-73a277d7534c">
                <item type="txt" lang="tau">nts'ą̈'</item>
              </word>
              <word>
                <item type="punct" lang="tau">/</item>
              </word>
              <word guid="823916a3-dd59-4cf5-b14b-9b320710d388">
