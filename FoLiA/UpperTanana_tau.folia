    </p>
    <p xml:id="_UTOLAF09Aug12.text.1.p.47">
      <s xml:id="_UTOLAF09Aug12.text.1.p.47.s.1">
        <t>"Nday? </t>
        <segnum>47.1</segnum>
        <w xml:id="_UTOLAF09Aug12.text.1.p.47.s.1.w.1">
          <t>Nday</t>
        </w>
