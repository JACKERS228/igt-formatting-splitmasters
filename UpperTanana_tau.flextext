        </phrases>
      </paragraph>
      <paragraph guid="6251834b-abb7-48a0-8c85-f78973583bd8">
        <phrases>
          <phrase guid="1ab12404-20c7-4c1d-a07c-4d31cc728c97">
            <item type="txt" lang="tau">Meh nats'elmoo.</item>
            <item type="segnum" lang="en">4</item>
