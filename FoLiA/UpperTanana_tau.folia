        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.42.s.1.w.5">
          <t>ch'a</t>
        </w>
        <w xml:id="_UTOLAF09Aug12.text.1.p.42.s.1.w.6">
          <t>dįh'ąy</t>
        </w>
      </s>
      <s xml:id="_UTOLAF09Aug12.text.1.p.42.s.2">
        <t>shehnih.</t>
        <segnum>42.2</segnum>
        <w xml:id="_UTOLAF09Aug12.text.1.p.42.s.2.w.1">
          <t>shehnih</t>
        </w>
